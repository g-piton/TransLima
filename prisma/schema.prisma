generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  phone       String
  serviceType String
  origin      String
  destination String
  desiredDate DateTime
  message     String?
  createdAt   DateTime @default(now())
}
